{% extends 'layout.html.twig' %}

{% block title %}Update Course - eLEARNING{% endblock %}

{% block css %}
    <link rel="stylesheet" href="{{ asset('css/custom.css') }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.0/dist/katex.min.css" crossorigin="anonymous">
    <style>
        body { background-color: #f4f7fc; font-family: 'Inter', sans-serif; }
        .course-create-header {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            color: #ffffff; padding: 80px 0; border-radius: 0 0 24px 24px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15); position: relative; overflow: hidden;
        }
        .course-create-header::before {
            content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background: url('https://www.transparenttextures.com/patterns/subtle-dots.png'); opacity: 0.1;
        }
        .course-create-header h1 {
            font-size: 2.8rem; font-weight: 800; text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2);
        }
        .course-create-header .lead {
            font-size: 1.3rem; max-width: 700px; margin: 0 auto; opacity: 0.9;
        }
        .form-section .card {
            background: #ffffff; border: none; border-radius: 16px; box-shadow: 0 6px 24px rgba(0, 0, 0, 0.1); padding: 2rem;
        }
        .form-section .form-control {
            border-radius: 10px; border: 1px solid #e2e8f0; padding: 12px;
        }
        .form-section .form-control:focus {
            border-color: #2a5298; box-shadow: 0 0 0 3px rgba(42, 82, 152, 0.2);
        }
        .part-form, .quiz-form {
            background: #f9fafb; border-radius: 12px; padding: 1.5rem; margin-bottom: 1.5rem;
        }
        .mce-content-body { min-height: 150px !important; border-radius: 8px; border: 1px solid #e2e8f0; }
        .add-part-btn, .add-media-btn, .add-question-btn, .add-option-btn {
            border-radius: 50px; padding: 0.6rem 1.8rem; font-weight: 600; background-color: #2a5298; color: #ffffff;
        }
        .remove-part-btn, .remove-media-btn, .remove-question-btn, .remove-option-btn {
            border-radius: 50px; padding: 0.6rem 1.8rem; font-weight: 600; background-color: #dc3545; color: #ffffff;
        }
        .media-url-container, .question-container, .option-container { margin-bottom: 1rem; }
        h1, h2, h3, h4, h5, h6 { color: #2a5298; }
        .quiz-toggle { margin-bottom: 1rem; }
        .geogebra-container {
            min-height: 400px; position: relative;
        }
        .geogebra-container #geogebra-element- {
            width: 100% !important; height: 100% !important; min-height: 400px;
        }
        @media (max-width: 768px) {
            .course-create-header { padding: 40px 0; }
            .course-create-header h1 { font-size: 2rem; }
            .form-section .card { padding: 1.5rem; }
        }
    </style>
{% endblock %}

{% block body %}
    <section class="course-create-header animate__animated animate__fadeIn">
        <div class="container text-center">
            <h1 class="display-4 fw-bold">Update Course: {{ course.title }}</h1>
            <p class="lead">Modify your numerical analysis course with rich, interactive content.</p>
        </div>
    </section>

    <section class="form-section py-5">
        <div class="container">
            <div class="card shadow-sm rounded-3">
                {{ form_start(form, {'attr': {'enctype': 'multipart/form-data', 'id': 'course-update-form'}}) }}
                    {{ form_widget(form._token) }}
                    <div class="mb-4">
                        {{ form_row(form.title, {'attr': {'class': 'form-control form-control-lg', 'placeholder': 'Enter course title'}}) }}
                    </div>
                    <div class="mb-4">
                        {{ form_row(form.description, {'attr': {'class': 'form-control', 'placeholder': 'Describe your course'}}) }}
                    </div>
                    <div class="mb-4">
                        {{ form_row(form.image, {'attr': {'class': 'form-control'}}) }}
                    </div>

                    <h3 class="fw-bold mb-4">Course Parts</h3>
                    <div id="parts-container" data-prototype="{{ form_widget(form.parts.vars.prototype)|e('html_attr')|replace({'__name__': '0'})|raw }}">
                        {% for partForm in form.parts %}
                            <div class="part-form card shadow-sm rounded-3" data-part-index="{{ loop.index0 }}">
                                <h4 class="fw-bold">Part {{ loop.index }}</h4>
                                <div class="row mb-3">
                                    <div class="col-md-6">
                                        {{ form_row(partForm.title, {'attr': {'class': 'form-control', 'placeholder': 'Part title'}}) }}
                                    </div>
                                    <div class="col-md-3">
                                        {{ form_row(partForm.partOrder, {'attr': {'class': 'form-control'}}) }}
                                    </div>
                                    <div class="col-md-3">
                                        {{ form_row(partForm.duration, {'attr': {'class': 'form-control'}}) }}
                                    </div>
                                </div>
                                <div class="mb-3">
                                    {{ form_row(partForm.description, {'label': 'Part Description', 'attr': {'class': 'form-control', 'placeholder': 'Enter a brief part description'}}) }}
                                </div>
                                <h5 class="fw-bold">Video Content</h5>
                                <div class="row mb-3">
                                    <div class="col-md-12">
                                        {{ form_row(partForm.videoFile, {'attr': {'class': 'form-control'}}) }}
                                    </div>
                                </div>
                                <div class="mb-3">
                                    {{ form_row(partForm.videoDescription, {'attr': {'class': 'form-control', 'placeholder': 'Video description'}}) }}
                                </div>
                                <h5 class="fw-bold">GeoGebra Content</h5>
                                <div class="mb-3">
                                    {{ form_row(partForm.geogebraMaterialId, {'attr': {'class': 'form-control', 'placeholder': 'GeoGebra material ID'}}) }}
                                </div>
                                <div class="geogebra-container">
                                    <div class="loading-spinner" id="ggb-spinner-{{ loop.index0 }}"></div>
                                    <div id="geogebra-element-{{ loop.index0 }}" style="width: 100%; height: 400px;"></div>
                                </div>
                                <div class="mb-3">
                                    {{ form_row(partForm.tutorialContent, {'label': 'Tutorial Content', 'attr': {'class': 'form-control', 'placeholder': 'Enter tutorial content'}}) }}
                                </div>
                                <h5 class="fw-bold">Written Content</h5>
                                <div class="mb-3">
                                    {{ form_row(partForm.writtenSection.content, {
                                        'id': 'written_section_' ~ loop.index0 ~ '_content',
                                        'attr': {'class': 'form-control rich-text-editor'}
                                    }) }}
                                    <div class="help-text">Use headings, images, videos, and LaTeX (e.g., \( x^2 \)) for mathematical expressions.</div>
                                </div>
                                <div class="mb-3">
                                    <label class="fw-bold">Media URLs</label>
                                    <div class="media-urls-container" data-part-index="{{ loop.index0 }}">
                                        {% for mediaUrlField in partForm.writtenSection.mediaUrls %}
                                            <div class="media-url-container row mb-2">
                                                <div class="col-md-10">
                                                    {{ form_widget(mediaUrlField, {'attr': {'class': 'form-control media-url', 'placeholder': 'e.g., https://example.com/image.jpg'}}) }}
                                                </div>
                                                <div class="col-md-2">
                                                    <button type="button" class="btn remove-media-btn mt-1">Remove</button>
                                                </div>
                                            </div>
                                        {% endfor %}
                                        <button type="button" class="btn add-media-btn mt-2" data-part-index="{{ loop.index0 }}">Add Media URL</button>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    {{ form_row(partForm.writtenSection.mediaUploads) }}
                                    <button type="button" class="btn add-media-upload-btn mt-2" data-part-index="{{ loop.index0 }}">Add Media Upload</button>
                                </div>
                                <!-- Part Quiz Section -->
                                <h5 class="fw-bold">Part Quiz</h5>
                                <div class="quiz-form" id="quiz-form-part-{{ loop.index0 }}">
                                    <div class="quiz-toggle mb-3">
                                        {{ form_row(partForm.quizMode, {
                                            'attr': {
                                                'class': 'form-control quiz-mode',
                                                'data-part-index': loop.index0,
                                                'id': 'course_parts_' ~ loop.index0 ~ '_quizMode'
                                            }
                                        }) }}
                                    </div>
                                    <div class="manual-quiz-section" id="manual-quiz-part-{{ loop.index0 }}" style="display: none;">
                                        <div class="mb-3">
                                            {{ form_label(partForm.quiz.title, 'Quiz Title') }}
                                            {{ form_widget(partForm.quiz.title, {
                                                'attr': {
                                                    'class': 'form-control',
                                                    'placeholder': 'Enter quiz title',
                                                    'id': 'course_parts_' ~ loop.index0 ~ '_quiz_title'
                                                }
                                            }) }}
                                            {{ form_errors(partForm.quiz.title) }}
                                        </div>
                                        <div class="questions-container" id="questions-part-{{ loop.index0 }}"
                                             data-part-index="{{ loop.index0 }}"
                                             data-prototype="{{ form_widget(partForm.quiz.questions.vars.prototype)|e('html_attr')|replace({'__name__': '0'})|raw }}">
                                            {% for questionForm in partForm.quiz.questions %}
                                                <div class="question-form card shadow-sm rounded-3 mb-2" data-question-index="{{ loop.index0 }}">
                                                    <div class="mb-3">
                                                        {{ form_label(questionForm.text, 'Question Text') }}
                                                        {{ form_widget(questionForm.text, {
                                                            'id': 'course_parts_' ~ loop.parent.loop.index0 ~ '_quiz_questions_' ~ loop.index0 ~ '_text',
                                                            'attr': {'class': 'form-control rich-text-editor'}
                                                        }) }}
                                                        {{ form_errors(questionForm.text) }}
                                                    </div>
                                                    <div class="mb-3">
                                                        {{ form_label(questionForm.type, 'Question Type') }}
                                                        {{ form_widget(questionForm.type, {
                                                            'attr': {
                                                                'class': 'form-control question-type',
                                                                'data-question-index': loop.index0,
                                                                'id': 'course_parts_' ~ loop.parent.loop.index0 ~ '_quiz_questions_' ~ loop.index0 ~ '_type'
                                                            }
                                                        }) }}
                                                        {{ form_errors(questionForm.type) }}
                                                    </div>
                                                    <div class="options-container" id="options-part-{{ loop.parent.loop.index0 }}-{{ loop.index0 }}" data-dependent="mcq" style="display: none;">
                                                        {% for option in questionForm.options %}
                                                            <div class="option-container row mb-2">
                                                                <div class="col-md-10">
                                                                    {{ form_widget(option, {
                                                                        'attr': {
                                                                            'class': 'form-control',
                                                                            'placeholder': 'Enter option'
                                                                        }
                                                                    }) }}
                                                                    {{ form_errors(option) }}
                                                                </div>
                                                                <div class="col-md-2">
                                                                    <button type="button" class="btn remove-option-btn mt-1">Remove Option</button>
                                                                </div>
                                                            </div>
                                                        {% endfor %}
                                                        <button type="button" class="btn add-option-btn mt-2" data-question-index="{{ loop.index0 }}" data-part-index="{{ loop.parent.loop.index0 }}">Add Option</button>
                                                    </div>
                                                    <div class="mb-3">
                                                        {{ form_label(questionForm.correctAnswer, 'Correct Answer') }}
                                                        {{ form_widget(questionForm.correctAnswer, {
                                                            'attr': {
                                                                'class': 'form-control',
                                                                'placeholder': 'e.g., A or 42',
                                                                'id': 'course_parts_' ~ loop.parent.loop.index0 ~ '_quiz_questions_' ~ loop.index0 ~ '_correctAnswer'
                                                            }
                                                        }) }}
                                                        {{ form_errors(questionForm.correctAnswer) }}
                                                    </div>
                                                    {{ form_widget(questionForm.generatedByAI, {'attr': {'type': 'hidden'}}) }}
                                                    <button type="button" class="btn remove-question-btn mt-2">Remove Question</button>
                                                </div>
                                            {% endfor %}
                                            <button type="button" class="btn add-question-btn mt-2" data-part-index="{{ loop.index0 }}">Add Question</button>
                                        </div>
                                        <div class="help-text">Add exactly 10 questions for this quiz.</div>
                                    </div>
                                </div>
                                <button type="button" class="btn remove-part-btn mt-3">Remove Part</button>
                            </div>
                        {% endfor %}
                    </div>
                    <button type="button" class="btn add-part-btn mt-3">Add Part</button>

                    <!-- Final Course Quiz Section -->
                    <h3 class="fw-bold mb-4">Final Course Quiz</h3>
                    <div class="quiz-form card shadow-sm rounded-3" id="quiz-form-final">
                        <div class="quiz-toggle mb-3">
                            {{ form_row(form.quizMode, {
                                'attr': {
                                    'class': 'form-control quiz-mode',
                                    'id': 'course_quizMode',
                                    'data-part-index': 'final'
                                }
                            }) }}
                        </div>
                        <div class="manual-quiz-section" id="manual-quiz-final" style="display: none;">
                            <div class="mb-3">
                                {{ form_label(form.finalQuiz.title, 'Final Quiz Title') }}
                                {{ form_widget(form.finalQuiz.title, {
                                    'attr': {
                                        'class': 'form-control',
                                        'placeholder': 'Enter final quiz title',
                                        'id': 'course_finalQuiz_title'
                                    }
                                }) }}
                                {{ form_errors(form.finalQuiz.title) }}
                            </div>
                            <div class="questions-container final-quiz-questions" id="questions-final"
                                 data-part-index="final"
                                 data-prototype="{{ form_widget(form.finalQuiz.questions.vars.prototype)|e('html_attr')|replace({'__name__': '0'})|raw }}">
                                {% for questionForm in form.finalQuiz.questions %}
                                    <div class="question-form card shadow-sm rounded-3 mb-2" data-question-index="{{ loop.index0 }}">
                                        <div class="mb-3">
                                            {{ form_label(questionForm.text, 'Question Text') }}
                                            {{ form_widget(questionForm.text, {
                                                'id': 'course_finalQuiz_questions_' ~ loop.index0 ~ '_text',
                                                'attr': {'class': 'form-control rich-text-editor'}
                                            }) }}
                                            {{ form_errors(questionForm.text) }}
                                        </div>
                                        <div class="mb-3">
                                            {{ form_label(questionForm.type, 'Question Type') }}
                                            {{ form_widget(questionForm.type, {
                                                'attr': {
                                                    'class': 'form-control question-type',
                                                    'data-question-index': loop.index0,
                                                    'id': 'course_finalQuiz_questions_' ~ loop.index0 ~ '_type'
                                                }
                                            }) }}
                                            {{ form_errors(questionForm.type) }}
                                        </div>
                                        <div class="options-container" id="options-final-{{ loop.index0 }}" data-dependent="mcq" style="display: none;">
                                            {% for option in questionForm.options %}
                                                <div class="option-container row mb-2">
                                                    <div class="col-md-10">
                                                        {{ form_widget(option, {
                                                            'attr': {
                                                                'class': 'form-control',
                                                                'placeholder': 'Enter option'
                                                            }
                                                        }) }}
                                                        {{ form_errors(option) }}
                                                    </div>
                                                    <div class="col-md-2">
                                                        <button type="button" class="btn remove-option-btn mt-1">Remove Option</button>
                                                    </div>
                                                </div>
                                            {% endfor %}
                                            <button type="button" class="btn add-option-btn mt-2" data-question-index="{{ loop.index0 }}" data-part-index="final">Add Option</button>
                                        </div>
                                        <div class="mb-3">
                                            {{ form_label(questionForm.correctAnswer, 'Correct Answer') }}
                                            {{ form_widget(questionForm.correctAnswer, {
                                                'attr': {
                                                    'class': 'form-control',
                                                    'placeholder': 'e.g., A or 42',
                                                    'id': 'course_finalQuiz_questions_' ~ loop.index0 ~ '_correctAnswer'
                                                }
                                            }) }}
                                            {{ form_errors(questionForm.correctAnswer) }}
                                        </div>
                                        {{ form_widget(questionForm.generatedByAI, {'attr': {'type': 'hidden'}}) }}
                                        <button type="button" class="btn remove-question-btn mt-2">Remove Question</button>
                                    </div>
                                {% endfor %}
                                <button type="button" class="btn add-question-btn mt-2" data-part-index="final">Add Question</button>
                            </div>
                            <div class="help-text">Add exactly 10 questions for the final quiz.</div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" class="btn btn-primary btn-lg">Update Course</button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </section>
{% endblock %}

{% block js %}
    <script src="https://code.jquery.com/jquery-3.6.0.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.tiny.cloud/1/ifeinrsntzv3r5s66j2ixgo39jv7rz9otzj2xzg2nirgaloc/tinymce/8/tinymce.min.js" referrerpolicy="origin" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.0/dist/katex.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/katex@0.16.0/dist/contrib/auto-render.min.js" crossorigin="anonymous"></script>
    <script src="https://www.geogebra.org/apps/deployggb.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (typeof tinymce === 'undefined') {
                console.error('TinyMCE script failed to load. Check the CDN URL and ensure 127.0.0.1:8000 is added to approved domains at https://www.tiny.cloud/my-account/.');
                return;
            }

            // Initialize TinyMCE
            function initializeTinyMCE(element, id) {
                if (!element || element.hasAttribute('data-tinymce-initialized')) {
                    console.debug(`TinyMCE already initialized or element missing for ID: ${id}`);
                    return;
                }
                tinymce.init({
                    selector: `#${id}`,
                    plugins: ['image', 'media', 'link', 'lists', 'table', 'emoticons', 'code'],
                    toolbar: 'undo redo | bold italic | link image media | bullist numlist | emoticons',
                    content_css: 'https://cdn.jsdelivr.net/npm/katex@0.16.0/dist/katex.min.css',
                    images_upload_url: '/upload/image',
                    images_upload_handler: async function (blobInfo, success, failure) {
                        try {
                            const formData = new FormData();
                            formData.append('file', blobInfo.blob(), blobInfo.filename());
                            const response = await fetch('/upload/image', {
                                method: 'POST',
                                body: formData,
                                headers: { 'X-CSRF-TOKEN': document.querySelector('input[name="course[_token]"]').value }
                            });
                            if (!response.ok) throw new Error(`HTTP error! Status: ${response.status}`);
                            const result = await response.json();
                            if (result.location) success(result.location);
                            else failure('Upload failed: No location returned');
                        } catch (error) {
                            failure('Upload error: ' + error.message);
                        }
                    },
                    setup: function (editor) {
                        editor.on('init', function () {
                            renderMathInElement(editor.getContentAreaContainer(), {
                                delimiters: [
                                    { left: "$$", right: "$$", display: true },
                                    { left: "\\(", right: "\\)", display: false }
                                ]
                            });
                        });
                        editor.on('change', function () {
                            editor.save();
                        });
                    },
                    placeholder: 'Enter question with LaTeX support (e.g., \\(x^2 + y^2 = z^2\\))'
                }).then(function () {
                    element.setAttribute('data-tinymce-initialized', 'true');
                    console.debug(`TinyMCE initialized for ID: ${id}`);
                }).catch(function (error) {
                    console.error(`TinyMCE initialization failed for ID: ${id}`, error);
                });
            }

            // Initialize quiz section
            function initializeQuiz(quizForm, partIndex, isFinal = false) {
                const prefix = isFinal ? 'course_finalQuiz' : `course_parts_${partIndex}_quiz`;
                const quizFormId = isFinal ? 'quiz-form-final' : `quiz-form-part-${partIndex}`;
                const quizModeId = isFinal ? 'course_quizMode' : `course_parts_${partIndex}_quizMode`;
                const manualQuizId = isFinal ? 'manual-quiz-final' : `manual-quiz-part-${partIndex}`;
                const questionsId = isFinal ? 'questions-final' : `questions-part-${partIndex}`;

                const quizModeSelect = document.querySelector(`#${quizModeId}`);
                const manualQuizSection = document.querySelector(`#${manualQuizId}`);
                const questionsContainer = document.querySelector(`#${questionsId}`);

                if (!quizModeSelect) {
                    console.error(`Quiz mode select not found: #${quizModeId}`);
                    return;
                }
                if (!manualQuizSection) {
                    console.error(`Manual quiz section not found: #${manualQuizId}`);
                    return;
                }
                if (!questionsContainer) {
                    console.error(`Questions container not found: #${questionsId}`);
                    return;
                }

                let questionIndex = questionsContainer.querySelectorAll('.question-form').length;

                function toggleManualQuizSection() {
                    manualQuizSection.style.display = quizModeSelect.value === 'manual' ? 'block' : 'none';
                    console.debug(`Toggled manual quiz section for ${isFinal ? 'final quiz' : 'part ' + partIndex}: ${manualQuizSection.style.display}`);
                    if (quizModeSelect.value === 'manual') {
                        questionsContainer.querySelectorAll('.question-form').forEach((questionDiv, qIndex) => {
                            const textInput = questionDiv.querySelector(`#${prefix}_questions_${qIndex}_text`);
                            if (textInput) {
                                initializeTinyMCE(textInput, `${prefix}_questions_${qIndex}_text`);
                            }
                            initializeQuestion(questionDiv, partIndex, qIndex, isFinal);
                        });
                    }
                }

                quizModeSelect.addEventListener('change', toggleManualQuizSection);
                toggleManualQuizSection();

                const addQuestionButton = questionsContainer.querySelector('.add-question-btn');
                if (!addQuestionButton) {
                    console.error(`Add question button not found in questions container: #${questionsId}`);
                    return;
                }

                const prototype = questionsContainer.dataset.prototype;
                if (!prototype) {
                    console.error(`Questions prototype not found for ${isFinal ? 'final quiz' : 'part ' + partIndex}`);
                    return;
                }

                addQuestionButton.addEventListener('click', function () {
                    const newQuestionDiv = document.createElement('div');
                    newQuestionDiv.classList.add('question-form', 'card', 'shadow-sm', 'rounded-3', 'mb-2');
                    newQuestionDiv.setAttribute('data-question-index', questionIndex);
                    const optionsContainerId = isFinal ? `options-final-${questionIndex}` : `options-part-${partIndex}-${questionIndex}`;
                    newQuestionDiv.innerHTML = prototype
                        .replace(/__name__/g, questionIndex)
                        .replace(/id="[^"]*_text"/, `id="${prefix}_questions_${questionIndex}_text"`)
                        .replace(/id="[^"]*_type"/, `id="${prefix}_questions_${questionIndex}_type"`)
                        .replace(/id="[^"]*_correctAnswer"/, `id="${prefix}_questions_${questionIndex}_correctAnswer"`)
                        .replace(
                            /<div class="options-container"[^>]*>/,
                            `<div class="options-container" id="${optionsContainerId}" data-dependent="mcq" style="display: none;">`
                        );
                    try {
                        questionsContainer.insertBefore(newQuestionDiv, addQuestionButton);
                        const observer = new MutationObserver((mutations, obs) => {
                            const textInput = newQuestionDiv.querySelector(`#${prefix}_questions_${questionIndex}_text`);
                            const correctAnswerInput = newQuestionDiv.querySelector(`#${prefix}_questions_${questionIndex}_correctAnswer`);
                            if (textInput && correctAnswerInput) {
                                obs.disconnect();
                                if (textInput) {
                                    initializeTinyMCE(textInput, `${prefix}_questions_${questionIndex}_text`);
                                }
                                initializeQuestion(newQuestionDiv, partIndex, questionIndex, isFinal);
                                console.debug(`Added question ${questionIndex} to ${isFinal ? 'final quiz' : 'part ' + partIndex}`);
                                questionIndex++;
                            }
                        });
                        observer.observe(newQuestionDiv, { childList: true, subtree: true });
                    } catch (error) {
                        console.error(`Failed to add question to ${isFinal ? 'final quiz' : 'part ' + partIndex}: ${error.message}`);
                    }
                });

                questionsContainer.addEventListener('click', function (e) {
                    if (e.target.classList.contains('remove-question-btn')) {
                        const questionDiv = e.target.closest('.question-form');
                        const qIndex = questionDiv.getAttribute('data-question-index');
                        if (tinymce.get(`${prefix}_questions_${qIndex}_text`)) {
                            tinymce.get(`${prefix}_questions_${qIndex}_text`).remove();
                        }
                        questionDiv.remove();
                        console.debug(`Removed question ${qIndex} from ${isFinal ? 'final quiz' : 'part ' + partIndex}`);
                    }
                });

                questionsContainer.querySelectorAll('.question-form').forEach((questionDiv, qIndex) => {
                    const textInput = questionDiv.querySelector(`#${prefix}_questions_${qIndex}_text`);
                    if (textInput) {
                        initializeTinyMCE(textInput, `${prefix}_questions_${qIndex}_text`);
                    }
                    initializeQuestion(questionDiv, partIndex, qIndex, isFinal);
                });
            }

            // Initialize question
            function initializeQuestion(questionDiv, partIndex, questionIndex, isFinal = false) {
                const prefix = isFinal ? 'course_finalQuiz' : `course_parts_${partIndex}_quiz`;
                const optionsContainerId = isFinal ? `options-final-${questionIndex}` : `options-part-${partIndex}-${questionIndex}`;
                const typeSelectId = `${prefix}_questions_${questionIndex}_type`;
                let optionsContainer = questionDiv.querySelector(`#${optionsContainerId}`);
                const typeSelect = questionDiv.querySelector(`#${typeSelectId}`);
                const addOptionButton = questionDiv.querySelector(`.add-option-btn[data-question-index="${questionIndex}"]`);
                const correctAnswerInput = questionDiv.querySelector(`#${prefix}_questions_${questionIndex}_correctAnswer`);

                if (!optionsContainer) {
                    console.warn(`Options container not found: #${optionsContainerId}. Creating new one.`);
                    optionsContainer = document.createElement('div');
                    optionsContainer.classList.add('options-container');
                    optionsContainer.id = optionsContainerId;
                    optionsContainer.setAttribute('data-dependent', 'mcq');
                    optionsContainer.style.display = 'none';
                    if (correctAnswerInput && correctAnswerInput.parentNode === questionDiv) {
                        questionDiv.insertBefore(optionsContainer, correctAnswerInput);
                    } else {
                        questionDiv.appendChild(optionsContainer);
                    }
                }

                if (!typeSelect) {
                    console.error(`Question type select not found: #${typeSelectId}`);
                    return;
                }
                if (!addOptionButton) {
                    console.error(`Add option button not found for question ${questionIndex}`);
                    return;
                }

                function toggleOptions() {
                    optionsContainer.style.display = typeSelect.value === 'mcq' ? 'block' : 'none';
                    console.debug(`Toggled options for question ${questionIndex} in ${isFinal ? 'final quiz' : 'part ' + partIndex}: ${optionsContainer.style.display}`);
                }

                toggleOptions();
                typeSelect.addEventListener('change', toggleOptions);

                const prototype = `
                    <div class="option-container row mb-2">
                        <div class="col-md-10">
                            <input type="text" name="${prefix}[questions][${questionIndex}][options][]" class="form-control" placeholder="Enter option">
                        </div>
                        <div class="col-md-2">
                            <button type="button" class="btn remove-option-btn mt-1">Remove Option</button>
                        </div>
                    </div>
                `;

                addOptionButton.addEventListener('click', function () {
                    const newOptionDiv = document.createElement('div');
                    newOptionDiv.innerHTML = prototype;
                    optionsContainer.insertBefore(newOptionDiv.firstChild, addOptionButton);
                    console.debug(`Added option to question ${questionIndex} in ${isFinal ? 'final quiz' : 'part ' + partIndex}`);
                });

                optionsContainer.addEventListener('click', function (e) {
                    if (e.target.classList.contains('remove-option-btn')) {
                        e.target.closest('.option-container').remove();
                        console.debug(`Removed option from question ${questionIndex} in ${isFinal ? 'final quiz' : 'part ' + partIndex}`);
                    }
                });
            }

            // Initialize media URLs
            function initializeMediaUrls(partDiv, index) {
                const mediaUrlsContainer = partDiv.querySelector(`.media-urls-container[data-part-index="${index}"]`);
                if (!mediaUrlsContainer) return;
                const addMediaButton = mediaUrlsContainer.querySelector('.add-media-btn');
                const prototype = `
                    <div class="media-url-container row mb-2">
                        <div class="col-md-10">
                            <input type="url" name="course[parts][${index}][writtenSection][mediaUrls][]" class="form-control media-url" placeholder="e.g., https://example.com/image.jpg">
                        </div>
                        <div class="col-md-2">
                            <button type="button" class="btn remove-media-btn mt-1">Remove</button>
                        </div>
                    </div>
                `;
                addMediaButton.addEventListener('click', function () {
                    const newMediaDiv = document.createElement('div');
                    newMediaDiv.innerHTML = prototype;
                    mediaUrlsContainer.insertBefore(newMediaDiv.firstChild, addMediaButton);
                });
                mediaUrlsContainer.addEventListener('click', function (e) {
                    if (e.target.classList.contains('remove-media-btn')) {
                        e.target.closest('.media-url-container').remove();
                    }
                });
            }

            // Initialize media uploads
            function initializeMediaUploads(partDiv, index) {
                const mediaUploadsContainer = partDiv.querySelector(`[id^="course_parts_${index}_writtenSection_mediaUploads"]`);
                if (!mediaUploadsContainer) return;
                const addMediaUploadButton = partDiv.querySelector(`.add-media-upload-btn[data-part-index="${index}"]`);
                const prototype = `
                    <div class="media-upload-container row mb-2">
                        <div class="col-md-10">
                            <input type="file" name="course[parts][${index}][writtenSection][mediaUploads][]" class="form-control">
                        </div>
                        <div class="col-md-2">
                            <button type="button" class="btn remove-media-upload-btn mt-1">Remove</button>
                        </div>
                    </div>
                `;
                addMediaUploadButton.addEventListener('click', function () {
                    const newMediaDiv = document.createElement('div');
                    newMediaDiv.innerHTML = prototype;
                    mediaUploadsContainer.insertBefore(newMediaDiv.firstChild, addMediaUploadButton);
                });
                mediaUploadsContainer.addEventListener('click', function (e) {
                    if (e.target.classList.contains('remove-media-upload-btn')) {
                        e.target.closest('.media-upload-container').remove();
                    }
                });
            }

            // Initialize parts
            const partsContainer = document.getElementById('parts-container');
            const addPartButton = document.querySelector('.add-part-btn');
            let partIndex = document.querySelectorAll('.part-form').length;

            if (!partsContainer) {
                console.error('Parts container not found: #parts-container');
                return;
            }
            if (!addPartButton) {
                console.error('Add part button not found: .add-part-btn');
                return;
            }

            function initializePart(partDiv, index) {
                initializeTinyMCE(partDiv.querySelector(`#written_section_${index}_content`), `written_section_${index}_content`);
                initializeMediaUrls(partDiv, index);
                initializeMediaUploads(partDiv, index);
                const quizForm = partDiv.querySelector(`#quiz-form-part-${index}`);
                if (quizForm) {
                    initializeQuiz(quizForm, index);
                } else {
                    console.error(`Quiz form not found for part ${index}`);
                }
                const ggbSpinner = partDiv.querySelector(`#ggb-spinner-${index}`);
                if (ggbSpinner) ggbSpinner.style.display = 'block';
                const ggbContainer = partDiv.querySelector(`#geogebra-element-${index}`);
                if (ggbContainer) {
                    const materialId = partDiv.querySelector(`[name="course[parts][${index}][geogebraMaterialId]"]`).value || '';
                    const ggbApp = new GGBApplet({
                        appName: 'graphing',
                        width: ggbContainer.offsetWidth,
                        height: 400,
                        showToolBar: true,
                        showAlgebraInput: true,
                        showMenuBar: true,
                        material_id: materialId
                    }, true);
                    ggbApp.inject(`geogebra-element-${index}`, function() {
                        if (ggbSpinner) ggbSpinner.style.display = 'none';
                        const ggbInstance = window[`ggbApplet${index.replace(/-/g, '')}`];
                        if (ggbInstance) {
                            ggbInstance.registerAddListener(function(json) {
                                console.log(`GeoGebra interaction detected for part ${index}:`, json);
                            });
                        }
                    }, function(error) {
                        if (ggbSpinner) ggbSpinner.style.display = 'none';
                        ggbContainer.innerHTML = '<p class="text-danger">Failed to load GeoGebra applet. Please try again later.</p>';
                    });
                }
            }

            document.querySelectorAll('.part-form').forEach((partDiv, index) => {
                initializePart(partDiv, index);
            });

            const finalQuizForm = document.querySelector('#quiz-form-final');
            if (finalQuizForm) {
                initializeQuiz(finalQuizForm, 'final', true);
            } else {
                console.error('Final quiz form not found');
            }

            addPartButton.addEventListener('click', function () {
                const prototype = partsContainer.dataset.prototype.replace(/__name__/g, partIndex);
                const newPartDiv = document.createElement('div');
                newPartDiv.classList.add('part-form', 'card', 'shadow-sm', 'rounded-3');
                newPartDiv.setAttribute('data-part-index', partIndex);

                const parser = new DOMParser();
                const doc = parser.parseFromString(prototype, 'text/html');
                let titleDiv = '', descriptionDiv = '', durationDiv = '', orderDiv = '', videoFileDiv = '', videoDescDiv = '', geoDiv = '', tutorialDiv = '', writtenDiv = '', mediaUrlsDiv = '', mediaUploadsDiv = '', quizDiv = '', quizModeDiv = '', questionsPrototype = '';

                for (let div of doc.getElementsByTagName('div')) {
                    if (div.querySelector('input[name$="[title]"]')) titleDiv = div.outerHTML;
                    else if (div.querySelector('textarea[name$="[description]"]')) descriptionDiv = div.outerHTML;
                    else if (div.querySelector('input[name$="[duration]"]')) durationDiv = div.outerHTML;
                    else if (div.querySelector('input[name$="[partOrder]"]')) orderDiv = div.outerHTML;
                    else if (div.querySelector('input[name$="[videoFile]"]')) videoFileDiv = div.outerHTML;
                    else if (div.querySelector('textarea[name$="[videoDescription]"]')) videoDescDiv = div.outerHTML;
                    else if (div.querySelector('input[name$="[geogebraMaterialId]"]')) geoDiv = div.outerHTML;
                    else if (div.querySelector('textarea[name$="[tutorialContent]"]')) tutorialDiv = div.outerHTML;
                    else if (div.querySelector('textarea[name$="[writtenSection][content]"]')) writtenDiv = div.outerHTML;
                    else if (div.querySelector('input[name$="[writtenSection][mediaUrls][]"]')) mediaUrlsDiv = div.outerHTML;
                    else if (div.querySelector('input[name$="[writtenSection][mediaUploads][]"]')) mediaUploadsDiv = div.outerHTML;
                    else if (div.querySelector('input[name$="[quiz][title]"]')) quizDiv = div.outerHTML;
                    else if (div.querySelector('select[name$="[quizMode]"]')) quizModeDiv = div.outerHTML;
                    else if (div.querySelector('div[id$="_quiz_questions"]')) questionsPrototype = div.outerHTML;
                }

                newPartDiv.innerHTML = `
                    <h4 class="fw-bold">Part ${partIndex + 1}</h4>
                    <div class="row mb-3">
                        <div class="col-md-6">${titleDiv}</div>
                        <div class="col-md-3">${orderDiv}</div>
                        <div class="col-md-3">${durationDiv}</div>
                    </div>
                    <div class="mb-3">${descriptionDiv}</div>
                    <h5 class="fw-bold">Video Content</h5>
                    <div class="row mb-3">
                        <div class="col-md-12">${videoFileDiv}</div>
                    </div>
                    <div class="mb-3">${videoDescDiv}</div>
                    <h5 class="fw-bold">GeoGebra Content</h5>
                    <div class="mb-3">${geoDiv}</div>
                    <div class="geogebra-container">
                        <div class="loading-spinner" id="ggb-spinner-${partIndex}"></div>
                        <div id="geogebra-element-${partIndex}" style="width: 100%; height: 400px;"></div>
                    </div>
                    <div class="mb-3">${tutorialDiv}</div>
                    <h5 class="fw-bold">Written Content</h5>
                    <div class="mb-3">${writtenDiv}</div>
                    <div class="mb-3">
                        <label class="fw-bold">Media URLs</label>
                        <div class="media-urls-container" data-part-index="${partIndex}">
                            ${mediaUrlsDiv}
                            <button type="button" class="btn add-media-btn mt-2" data-part-index="${partIndex}">Add Media URL</button>
                        </div>
                    </div>
                    <div class="mb-3">
                        ${mediaUploadsDiv}
                        <button type="button" class="btn add-media-upload-btn mt-2" data-part-index="${partIndex}">Add Media Upload</button>
                    </div>
                    <h5 class="fw-bold">Part Quiz</h5>
                    <div class="quiz-form" id="quiz-form-part-${partIndex}">
                        <div class="quiz-toggle mb-3">${quizModeDiv}</div>
                        <div class="manual-quiz-section" id="manual-quiz-part-${partIndex}" style="display: none;">
                            ${quizDiv}
                            <div class="questions-container" id="questions-part-${partIndex}" data-part-index="${partIndex}" data-prototype='${questionsPrototype.replace(/__name__/g, '0')}'>
                                <button type="button" class="btn add-question-btn mt-2" data-part-index="${partIndex}">Add Question</button>
                            </div>
                            <div class="help-text">Add exactly 10 questions for this quiz.</div>
                        </div>
                    </div>
                    <button type="button" class="btn remove-part-btn mt-3">Remove Part</button>
                `;

                try {
                    partsContainer.appendChild(newPartDiv);
                    initializePart(newPartDiv, partIndex);
                    console.debug(`Added part ${partIndex}`);
                    partIndex++;
                } catch (error) {
                    console.error(`Failed to add part ${partIndex}: ${error.message}`);
                }
            });

            // Remove part
            partsContainer.addEventListener('click', function (e) {
                if (e.target.classList.contains('remove-part-btn')) {
                    const partDiv = e.target.closest('.part-form');
                    const index = partDiv.getAttribute('data-part-index');
                    const textInput = partDiv.querySelector(`#written_section_${index}_content`);
                    if (textInput && tinymce.get(`written_section_${index}_content`)) {
                        tinymce.get(`written_section_${index}_content`).remove();
                    }
                    const quizQuestions = partDiv.querySelectorAll(`#questions-part-${index} .question-form`);
                    quizQuestions.forEach((questionDiv, qIndex) => {
                        const textInput = questionDiv.querySelector(`#course_parts_${index}_quiz_questions_${qIndex}_text`);
                        if (textInput && tinymce.get(`course_parts_${index}_quiz_questions_${qIndex}_text`)) {
                            tinymce.get(`course_parts_${index}_quiz_questions_${qIndex}_text`).remove();
                        }
                    });
                    partDiv.remove();
                    console.debug(`Removed part ${index}`);
                }
            });

            // Form submission validation
            document.getElementById('course-update-form').addEventListener('submit', function (e) {
                let isValid = true;
                const finalQuizMode = document.querySelector('#course_quizMode');
                const finalQuizQuestions = document.querySelectorAll('#questions-final .question-form').length;

                if (!finalQuizMode) {
                    console.error('Final quiz mode select not found');
                    isValid = false;
                } else if (finalQuizMode.value === 'manual' && finalQuizQuestions !== 10) {
                    alert('Final quiz must have exactly 10 questions.');
                    isValid = false;
                }

                document.querySelectorAll('.part-form').forEach((partDiv, index) => {
                    const quizMode = partDiv.querySelector(`#course_parts_${index}_quizMode`);
                    const questions = partDiv.querySelectorAll(`#questions-part-${index} .question-form`).length;
                    if (quizMode && quizMode.value === 'manual' && questions !== 10) {
                        alert(`Part ${index + 1} quiz must have exactly 10 questions.`);
                        isValid = false;
                    }
                });

                if (!isValid) {
                    e.preventDefault();
                }
            });

            // Render LaTeX
            renderMathInElement(document.body, {
                delimiters: [
                    { left: "$$", right: "$$", display: true },
                    { left: "\\(", right: "\\)", display: false }
                ]
            });
        });
    </script>
{% endblock %}